{
  "name": "trader-v2",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/index.ts | bunx pino-pretty",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --fix .",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "test": "bun test --preload ./tests/preload.ts",
    "eval": "bun src/evals/run.ts",
    "eval:classifier": "bun src/evals/run.ts classifier",
    "eval:pre-filter": "bun src/evals/run.ts pre-filter",
    "eval:pipeline": "bun src/evals/run.ts pipeline",
    "eval:evolution": "bun run src/evals/run.ts evolution",
    "monitor": "bun run scripts/open-dashboard.ts",
    "monitor:old": "cd monitor && bun run build && bun run server.ts",
    "monitor:dev": "cd monitor && bun run server.ts & bun run dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@octokit/rest": "^22.0.1",
    "@stoqey/ib": "^1.5.3",
    "cron-parser": "^5.5.0",
    "drizzle-orm": "^0.45.1",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "resend": "^6.9.2",
    "rss-parser": "^3.13.0",
    "rxjs": "^7.8.1",
    "yahoo-finance2": "^3.13.0",
    "zod": "^4.3.6"
  }
}

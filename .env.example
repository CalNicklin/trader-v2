# Trader v2 — environment configuration template
#
# Copy to `.env` and fill in the required values. The config schema in
# `src/config.ts` is the source of truth for which variables are required.

# ─── Required secrets ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
RESEND_API_KEY=
ALERT_EMAIL_TO=
FMP_API_KEY=

# ─── Optional runtime config ───────────────────────────────────────────────
DB_PATH=./data/trader.db
LOG_LEVEL=info
DAILY_API_BUDGET_USD=0

# ─── Live trading kill switch ──────────────────────────────────────────────
LIVE_TRADING_ENABLED=false

# ─── News pipeline feature flags ───────────────────────────────────────────
# Set RESEARCH_WHITELIST_ENFORCE=false to disable the whitelist filter in the
# research agent (kill switch — reverts to pre-2026-04-10 behaviour).
RESEARCH_WHITELIST_ENFORCE=true
